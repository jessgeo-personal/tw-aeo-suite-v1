# ============================================
# COMPLETE .ENV FILE FOR AEO SUITE BACKEND
# ============================================
# Copy this entire file to: D:\MyApps\aeo-audit-tool-v1\backend\.env
# Update the placeholder values with your actual keys

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=8080
# FRONTEND_URL not needed locally - React proxy handles it

# ============================================
# --- URLs ---
# ============================================
# Local React frontend typically runs on 3000
FRONTEND_URL=http://localhost:3000
# Point the frontend to the local backend port
REACT_APP_API_URL=http://localhost:8080

# ============================================
# MONGODB DATABASE
# ============================================
# Your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://jessthatworkx_db_user:[db-password]@aeo-tool-cluster.rrgmg0q.mongodb.net/aeo-staging?appName=AEO-Tool-Cluster&tls=true&tlsAllowInvalidCertificates=true


# ============================================
# SESSION MANAGEMENT
# ============================================
# Generate a strong random string for production
SESSION_SECRET=[session-secret-here]

# ============================================
# EMAIL SERVICE (RESEND)
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=[resend-api-key-here]

# Email Configuration
FROM_EMAIL=noreply-dev@thatworkx.com
EMAIL_FROM_NAME=AEO Tools by Thatworkx - DEV

# Enable/disable email verification
ENABLE_EMAIL_VERIFICATION=true

# ============================================
# HUBSPOT CRM INTEGRATION
# ============================================
# Get token from: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write, crm.schemas.contacts.read
HUBSPOT_ACCESS_TOKEN=[hubspot-access-token-here]
ENABLE_HUBSPOT_INTEGRATION=true

# ============================================
# USAGE LIMITS CONFIGURATION
# ============================================
# Enable daily usage limits
ENABLE_USAGE_LIMITS=true

# Daily limits per tool for free users
# Set to 0 for unlimited (not recommended for free tier)
DAILY_LIMIT_TECHNICAL=100
DAILY_LIMIT_CONTENT=100
DAILY_LIMIT_QUERY_MATCH=100
DAILY_LIMIT_VISIBILITY=100

# Alternative: Set global limit for all tools (overridden by tool-specific limits above)
# DAILY_LIMIT_ALL=3

# ============================================
# STRIPE PAYMENT PROCESSING
# ============================================
# Set to true when you're ready to accept payments
STRIPE_ENABLED=true

# Get these from: https://dashboard.stripe.com/test/apikeys
# Test keys (start with sk_test_ and pk_test_)
STRIPE_SECRET_KEY=sk_live_[here]
STRIPE_PUBLISHABLE_KEY=pk_live_[here]

# Webhook signing secret from: Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_[webhook-here]

# Price IDs from Stripe Dashboard → Products
# Create products in Stripe, then copy the Price IDs here
STRIPE_PRICE_PRO_MONTHLY=[price_1-here]
STRIPE_PRICE_PRO_ANNUAL=[price_1-here]

# ============================================
# OPTIONAL: RATE LIMITING
# ============================================
# General API rate limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# OPTIONAL: LOGGING
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# OPTIONAL: CORS CONFIGURATION
# ============================================
# Additional allowed origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# NOTES & REMINDERS
# ============================================

# MONGODB SETUP:
# 1. Go to MongoDB Atlas (cloud.mongodb.com)
# 2. Create cluster (free tier available)
# 3. Create database user
# 4. Get connection string
# 5. Replace <password> with your password
# 6. Add /aeo-suite after .mongodb.net and before ?retryWrites

# RESEND SETUP:
# 1. Sign up at resend.com
# 2. Verify your domain (thatworkx.com)
# 3. Get API key
# 4. Use noreply@thatworkx.com as FROM_EMAIL

# HUBSPOT SETUP:
# 1. Go to HubSpot → Settings → Integrations
# 2. Create Private App (Legacy Apps)
# 3. Add scopes: crm.objects.contacts.*, crm.schemas.contacts.*
# 4. Copy access token

# STRIPE SETUP (WHEN READY):
# 1. Create Stripe account at stripe.com
# 2. Complete business verification
# 3. Create 3 products:
#    - Monthly: $20/month
#    - 6 Months: $102 total ($17/month)
#    - Annual: $180 total ($15/month)
# 4. Copy Price IDs to this file
# 5. Set up webhook: https://yourdomain.com/api/subscription/webhook
# 6. Install: npm install stripe
# 7. Uncomment code in services/stripe.js
# 8. Set STRIPE_ENABLED=true
# 9. Restart backend

# PRODUCTION CHECKLIST:
# [ ] Change SESSION_SECRET to strong random string
# [ ] Update MONGODB_URI with production credentials
# [ ] Use production Stripe keys (sk_live_, pk_live_)
# [ ] Set FRONTEND_URL to your production domain
# [ ] Enable HTTPS
# [ ] Set NODE_ENV=production
# [ ] Review and tighten rate limits
# [ ] Set up monitoring and logging
# [ ] Configure backup strategy
# [ ] Test all integrations

# ============================================
# SECURITY WARNING
# ============================================
# NEVER commit this .env file to version control!
# Add .env to your .gitignore file
# Store production secrets in secure environment variable service
# Rotate keys regularly
# Use different keys for development and production

# Optional: Calendly Integration
CALENDLY_ACCESS_TOKEN=your-calendly-access-token-here
